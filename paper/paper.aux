\@writefile{lof}{\contentsline {figure}{\numberline {1}{\ignorespaces \textsc  {fastcxt} architecture. \textbf  {(a)}\nobreakspace  {}Overview: windowed SFS is compressed by a multi-scale convolutional stem, optionally summed with tree topology features, then processed by a 6-layer bidirectional Mamba encoder (FiLM-conditioned on $\log \mu $) and a 4-layer decoder with U-Net skip connections. \textbf  {(b)}\nobreakspace  {}Input preprocessing: genotypes are windowed, pairwise SFS computed, frequency-compressed, channel-merged, and processed by multi-scale convolutions. \textbf  {(c)}\nobreakspace  {}BiMamba block: two Mamba2 modules scan in opposite directions; outputs are concatenated and projected to $d$. Both sub-layers use pre-norm residual connections (grey). FiLM conditioning applies at encoder layers 0 and 5. \textbf  {(d)}\nobreakspace  {}Mamba2 module: input is expanded, convolved causally, processed by a structured state-space model ($d_\mathrm  {state}{=}64$), gated, and projected back to $d$.}}{4}{figure.1}\protected@file@percent }
\newlabel{fig:architecture}{{1}{4}{\textsc {fastcxt} architecture. \textbf {(a)}~Overview: windowed SFS is compressed by a multi-scale convolutional stem, optionally summed with tree topology features, then processed by a 6-layer bidirectional Mamba encoder (FiLM-conditioned on $\log \mu $) and a 4-layer decoder with U-Net skip connections. \textbf {(b)}~Input preprocessing: genotypes are windowed, pairwise SFS computed, frequency-compressed, channel-merged, and processed by multi-scale convolutions. \textbf {(c)}~BiMamba block: two Mamba2 modules scan in opposite directions; outputs are concatenated and projected to $d$. Both sub-layers use pre-norm residual connections (grey). FiLM conditioning applies at encoder layers 0 and 5. \textbf {(d)}~Mamba2 module: input is expanded, convolved causally, processed by a structured state-space model ($d_\mathrm {state}{=}64$), gated, and projected back to $d$}{figure.1}{}}
