\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Computational scaling (human-like 1\,Mb setup). (a)\nobreakspace  {}Inference time vs.\ sample size. (b)\nobreakspace  {}Speedup over the pairwise model: node-time only (NT) and full pipeline including tsinfer (Full). The same scaling applies to the AnoGam (100\,kb) pipeline.}}{12}{figure.5}\protected@file@percent }
\newlabel{fig:scaling}{{5}{12}{Computational scaling (human-like 1\,Mb setup). (a)~Inference time vs.\ sample size. (b)~Speedup over the pairwise model: node-time only (NT) and full pipeline including tsinfer (Full). The same scaling applies to the AnoGam (100\,kb) pipeline}{figure.5}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Pairwise coalescence times across \emph  {An.\,gambiae} chromosome\nobreakspace  {}2L (Ag1000G, Burkina Faso 2La heterozygotes). (a)\nobreakspace  {}Density heatmap: position $\times $ log(TMRCA) for within-individual pairs; dashed lines mark 2La inversion breakpoints. (b)\nobreakspace  {}Population-mean log(TMRCA) for \textsc  {fastcxt} (orange) and \texttt  {tsdate} (blue, rescaled to $\mu = 3.5 \times 10^{-9}$); blue shading marks the 2La inversion, red marks the Rdl locus.}}{12}{figure.6}\protected@file@percent }
\newlabel{fig:ag1000g}{{6}{12}{Pairwise coalescence times across \emph {An.\,gambiae} chromosome~2L (Ag1000G, Burkina Faso 2La heterozygotes). (a)~Density heatmap: position $\times $ log(TMRCA) for within-individual pairs; dashed lines mark 2La inversion breakpoints. (b)~Population-mean log(TMRCA) for \textsc {fastcxt} (orange) and \texttt {tsdate} (blue, rescaled to $\mu = 3.5 \times 10^{-9}$); blue shading marks the 2La inversion, red marks the Rdl locus}{figure.6}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {7}{\ignorespaces Training dynamics (validation loss) over 30 epochs. (a)\nobreakspace  {}Human-like models---blue: base (SFS-only); green: tree-augmented (true trees); orange: tree-augmented (tsinfer). (b)\nobreakspace  {}AnoGam tree-augmented (tsinfer, 100\,kb). (c)\nobreakspace  {}AnoGam tree-augmented (tsinfer, 400\,kb, 2{,}000 windows). All models converge smoothly without overfitting.}}{13}{figure.7}\protected@file@percent }
\newlabel{fig:training}{{7}{13}{Training dynamics (validation loss) over 30 epochs. (a)~Human-like models---blue: base (SFS-only); green: tree-augmented (true trees); orange: tree-augmented (tsinfer). (b)~AnoGam tree-augmented (tsinfer, 100\,kb). (c)~AnoGam tree-augmented (tsinfer, 400\,kb, 2{,}000 windows). All models converge smoothly without overfitting}{figure.7}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {8}{\ignorespaces Prediction residuals (predicted $-$ true) along the genome (left) and histograms (right). (a)\nobreakspace  {}Base (SFS-only), (b)\nobreakspace  {}tree-aug (true), (c)\nobreakspace  {}tree-aug (tsinfer)---all on human-like 1\,Mb; (d)\nobreakspace  {}AnoGam tree-aug (tsinfer, 100\,kb); (e)\nobreakspace  {}AnoGam tree-aug (tsinfer, 400\,kb, 2{,}000 windows). Mean and standard deviation annotated in each panel. All models show approximately centered, symmetric residuals with no spatial bias.}}{14}{figure.8}\protected@file@percent }
\newlabel{fig:residuals}{{8}{14}{Prediction residuals (predicted $-$ true) along the genome (left) and histograms (right). (a)~Base (SFS-only), (b)~tree-aug (true), (c)~tree-aug (tsinfer)---all on human-like 1\,Mb; (d)~AnoGam tree-aug (tsinfer, 100\,kb); (e)~AnoGam tree-aug (tsinfer, 400\,kb, 2{,}000 windows). Mean and standard deviation annotated in each panel. All models show approximately centered, symmetric residuals with no spatial bias}{figure.8}{}}
